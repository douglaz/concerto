# Example environment file for Concerto
# Copy this to .env and fill in your values

# PostgreSQL Configuration
POSTGRES_PASSWORD=changeme

# FeLaaS Provider Configuration
PROVIDER_NSEC=nsec1...your_provider_key_here
PROVIDER_NAME="My FeLaaS Provider"
BASE_SLOT_PRICE_SATS=100000

# Guardianito Configuration (for multiple instances)
# Guardian 1
OWNER_NPUB_1=npub1...owner1_public_key
GUARDIAN_NSEC_1=nsec1...guardian1_private_key

# Guardian 2
OWNER_NPUB_2=npub1...owner2_public_key
GUARDIAN_NSEC_2=nsec1...guardian2_private_key

# Guardian 3
OWNER_NPUB_3=npub1...owner3_public_key
GUARDIAN_NSEC_3=nsec1...guardian3_private_key

# Nostr Configuration
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.nostr.band,wss://nostr.wine

# Monitoring Configuration
GRAFANA_PASSWORD=admin

# Logging
RUST_LOG=info